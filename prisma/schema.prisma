// Prisma schema for the personal dashboard.
// area/status/priority/frequency are plain strings rather than native Postgres
// enums, so the allowed values live in one place: src/types/index.ts.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("USER") // "SUPER_ADMIN" | "USER"
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedTasks             Task[]                 @relation("TaskOwner")
  assignedTasks          Task[]                 @relation("TaskAssignee")
  taskCollaborations     TaskCollaborator[]
  ownedProjects          Project[]              @relation("ProjectOwner")
  projectCollaborations  ProjectCollaborator[]
  notes                  Note[]
  habits                 Habit[]
  documents              Document[]
  timezoneEntries        TimezoneEntry[]
  weatherLocations       WeatherLocation[]
  notificationRecipients NotificationRecipient[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  area        String // "BUSINESS" | "PERSONAL"
  status      String    @default("TODO") // "TODO" | "IN_PROGRESS" | "DONE"
  priority    String    @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH" | "URGENT"
  dueDate     DateTime?
  order       Int       @default(0)
  aiGenerated Boolean   @default(false)

  ownerId String?
  owner   User?   @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  collaborators TaskCollaborator[]

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  parentTaskId String?
  parentTask   Task?  @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     Task[] @relation("TaskSubtasks")

  notes Note[]

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([area, status])
  @@index([projectId])
  @@index([parentTaskId])
  @@index([dueDate])
  @@index([ownerId])
  @@index([assigneeId])
}

model TaskCollaborator {
  id      String   @id @default(cuid())
  taskId  String
  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@unique([taskId, userId])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  area        String // "BUSINESS" | "PERSONAL"
  status      String    @default("ACTIVE") // "PLANNED" | "ACTIVE" | "ON_HOLD" | "COMPLETED"
  color       String?
  dueDate     DateTime?
  order       Int       @default(0)

  ownerId String?
  owner   User?   @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  collaborators ProjectCollaborator[]

  tasks Task[]
  notes Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([area, status])
  @@index([ownerId])
}

model ProjectCollaborator {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([projectId, userId])
}

model Note {
  id      String  @id @default(cuid())
  title   String
  content String // markdown
  area    String // "BUSINESS" | "PERSONAL"
  tags    String? // comma-separated
  pinned  Boolean @default(false)

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([area])
  @@index([ownerId])
}

model Habit {
  id                String  @id @default(cuid())
  name              String
  area              String // "BUSINESS" | "PERSONAL"
  frequency         String  @default("DAILY") // "DAILY" | "WEEKLY" | "CUSTOM"
  targetDaysPerWeek Int?
  daysOfWeek        String? // "MON,WED,FRI" — used when frequency = CUSTOM
  color             String?
  active            Boolean @default(true)
  order             Int     @default(0)

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  logs HabitLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([area, active])
  @@index([ownerId])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime // normalized to UTC midnight, see src/lib/dates.ts
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([date])
}

model Document {
  id             String    @id @default(cuid())
  name           String // e.g. "Driver's License", "Passport"
  category       String    @default("OTHER") // "LICENSE" | "PASSPORT" | "INSURANCE" | "REGISTRATION" | "VISA" | "OTHER"
  area           String // "BUSINESS" | "PERSONAL"
  documentNumber String?
  issueDate      DateTime?
  expiryDate     DateTime?
  notes          String?

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([area])
  @@index([expiryDate])
  @@index([ownerId])
}

model NotificationRecipient {
  id           String   @id @default(cuid())
  label        String?
  email        String?
  whatsapp     String? // E.164, e.g. +15551234567
  dailyDigest  Boolean  @default(true)
  weeklyDigest Boolean  @default(true)
  active       Boolean  @default(true)

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model TimezoneEntry {
  id       String @id @default(cuid())
  label    String // e.g. "New York"
  timezone String // IANA name, e.g. "America/New_York"
  order    Int    @default(0)

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ownerId])
}

model WeatherLocation {
  id        String @id @default(cuid())
  label     String // e.g. "Johannesburg, South Africa"
  latitude  Float
  longitude Float
  order     Int    @default(0)

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ownerId])
}
